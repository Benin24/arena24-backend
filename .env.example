# ============================================
# Arena 24 — Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://arena24.in

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Email (Gmail SMTP)
EMAIL_FROM=Arena 24 <noreply@arena24.in>
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# Admin emails (comma-separated, these get admin role on register)
ADMIN_EMAILS=youremail@gmail.com,friend@gmail.com

# App URL (used in email links)
APP_URL=http://localhost:5000
# Production: APP_URL=https://api.arena24.in
